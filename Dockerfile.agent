# syntax=docker/dockerfile:1@sha256:2780b5c3bab67f1f76c781860de469442999ed1a0d7992a5efdf2cffc0e3d769
ARG DOCKER_CLI_IMAGE=docker:27-cli
ARG CLAUDE_NODE_IMAGE=node:24-slim@sha256:b506e7321f176aae77317f99d67a24b272c1f09f1d10f1761f2773447d8da26c
ARG CODEX_NODE_IMAGE=node:24-slim@sha256:b506e7321f176aae77317f99d67a24b272c1f09f1d10f1761f2773447d8da26c
ARG HELM_VERSION=v4.1.4

FROM ${DOCKER_CLI_IMAGE} AS dockercli

FROM dockercli AS agent-tools
ARG HELM_VERSION=v4.1.4
ARG TARGETARCH

RUN apk add --no-cache curl tar && \
    case "${TARGETARCH}" in \
      amd64|arm64) HELM_ARCH="${TARGETARCH}" ;; \
      *) echo "Unsupported TARGETARCH for Helm: ${TARGETARCH}" >&2; exit 1 ;; \
    esac && \
    curl -fsSL "https://get.helm.sh/helm-${HELM_VERSION}-linux-${HELM_ARCH}.tar.gz" -o /tmp/helm.tgz && \
    tar -xzf /tmp/helm.tgz -C /tmp && \
    mv /tmp/linux-${HELM_ARCH}/helm /usr/local/bin/helm && \
    chmod +x /usr/local/bin/helm && \
    rm -rf /tmp/helm.tgz /tmp/linux-${HELM_ARCH}

FROM ${CLAUDE_NODE_IMAGE} AS claude-base
ARG CLAUDE_CODE_VERSION=2.1.109

RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    gosu \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}

RUN usermod -l devops node && \
    groupmod -n devops node && \
    usermod -d /home/devops -m devops

WORKDIR /home/devops/project

FROM claude-base AS claude
COPY scripts/claude-entrypoint.sh /usr/local/bin/claude-entrypoint.sh
COPY scripts/agent-entrypoint-lib.sh /usr/local/bin/agent-entrypoint-lib.sh
RUN chmod +x /usr/local/bin/claude-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/claude-entrypoint.sh"]

FROM claude-base AS claude-docker
RUN mkdir -p /usr/local/libexec/docker/cli-plugins
COPY --from=agent-tools /usr/local/bin/docker /usr/local/bin/docker
COPY --from=agent-tools /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose
COPY --from=agent-tools /usr/local/bin/helm /usr/local/bin/helm
COPY scripts/claude-entrypoint.sh /usr/local/bin/claude-entrypoint.sh
COPY scripts/agent-entrypoint-lib.sh /usr/local/bin/agent-entrypoint-lib.sh
RUN chmod +x /usr/local/bin/claude-entrypoint.sh
ENTRYPOINT ["/usr/local/bin/claude-entrypoint.sh"]

FROM ${CODEX_NODE_IMAGE} AS codex-base
ARG CODEX_VERSION=0.121.0

RUN apt-get update && apt-get install -y --no-install-recommends \
    bubblewrap \
    git \
    curl \
    gosu \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex@${CODEX_VERSION}

RUN usermod -l devops node && \
    groupmod -n devops node && \
    usermod -d /home/devops -m devops

WORKDIR /home/devops/project

FROM codex-base AS codex
COPY scripts/codex-entrypoint.sh /usr/local/bin/codex-entrypoint.sh
COPY scripts/agent-entrypoint-lib.sh /usr/local/bin/agent-entrypoint-lib.sh
RUN chmod +x /usr/local/bin/codex-entrypoint.sh
ENTRYPOINT ["/usr/local/bin/codex-entrypoint.sh"]

FROM codex-base AS codex-docker
RUN mkdir -p /usr/local/libexec/docker/cli-plugins
COPY --from=agent-tools /usr/local/bin/docker /usr/local/bin/docker
COPY --from=agent-tools /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose
COPY --from=agent-tools /usr/local/bin/helm /usr/local/bin/helm
COPY scripts/codex-entrypoint.sh /usr/local/bin/codex-entrypoint.sh
COPY scripts/agent-entrypoint-lib.sh /usr/local/bin/agent-entrypoint-lib.sh
RUN chmod +x /usr/local/bin/codex-entrypoint.sh
ENTRYPOINT ["/usr/local/bin/codex-entrypoint.sh"]
