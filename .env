# Pinned Node.js base image digest for Claude agent
CLAUDE_NODE_IMAGE=node:24-slim@sha256:03eae3ef7e88a9de535496fb488d67e02b9d96a063a8967bae657744ecd513f2

# Pinned Node.js base image digest for Codex agent
CODEX_NODE_IMAGE=node:24-slim@sha256:03eae3ef7e88a9de535496fb488d67e02b9d96a063a8967bae657744ecd513f2

# Pinned Claude Code CLI version
CLAUDE_CODE_VERSION=2.1.114

# Pinned OpenAI Codex CLI version
CODEX_VERSION=0.121.0

# Local image tags
CLAUDE_IMAGE_NAME=ai-sandbox-claude-agent:local
CLAUDE_DOCKER_IMAGE_NAME=ai-sandbox-claude-agent-docker:local
CODEX_IMAGE_NAME=ai-sandbox-codex-agent:local
CODEX_DOCKER_IMAGE_NAME=ai-sandbox-codex-agent-docker:local

# Docker CLI image used only by Docker-enabled Codex profile.
DOCKER_CLI_IMAGE=docker:27-cli

# Rootless Docker daemon image used by Docker-enabled agent profiles.
DOCKER_DIND_IMAGE=docker:27-dind-rootless

# Helm CLI version installed in Docker-enabled Claude/Codex images.
HELM_VERSION=v3.18.4

# Optional host path mounted to /home/devops/project inside agent containers.
# If empty, default is: . (directory where docker compose is run).
AI_HOME_PATH=

# Optional host path mounted to /home/devops/.claude (persistent Claude home data).
# If empty, default is: $PWD/.claude (directory where docker compose is run).
CLAUDE_HOME_PATH=

# Optional host path mounted to /home/devops/.codex (persistent Codex home data).
# If empty, default is: $PWD/.codex (directory where docker compose is run).
CODEX_HOME_PATH=

# Optional runtime API keys for Compose secrets.
# Keep these empty in git; provide real values via exported env vars in your shell.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GITHUB_TOKEN=

# Optional Git identity injected into agent containers for commits.
GIT_USER_NAME=
GIT_USER_EMAIL=
