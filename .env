# Pinned Node.js base image digest for Claude agent
CLAUDE_NODE_IMAGE=node:24-slim@sha256:b506e7321f176aae77317f99d67a24b272c1f09f1d10f1761f2773447d8da26c

# Pinned Node.js base image digest for Codex agent
CODEX_NODE_IMAGE=node:24-slim@sha256:b506e7321f176aae77317f99d67a24b272c1f09f1d10f1761f2773447d8da26c

# Pinned Claude Code CLI version
CLAUDE_CODE_VERSION=2.1.114

# Pinned OpenAI Codex CLI version
CODEX_VERSION=0.121.0

# Local image tags
CLAUDE_IMAGE_NAME=ai-sandbox-claude-agent:local
CODEX_IMAGE_NAME=ai-sandbox-codex-agent:local

# Optional host path mounted to /home/devops/.codex (persistent Codex home data).
# If empty, default is: $PWD/.codex (directory where docker compose is run).
