{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "timezone": "Europe/Warsaw",
  "labels": [
    "dependencies",
    "renovate"
  ],
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "prCreation": "not-pending",
  "dependencyDashboard": true,
  "enabledManagers": [
    "github-actions",
    "dockerfile",
    "docker-compose",
    "custom.regex"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "groupName": "daily docker digests",
      "schedule": [
        "before 5am every weekday"
      ]
    },
    {
      "matchDatasources": [
        "docker",
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "replacement"
      ],
      "groupName": "weekly dependency updates",
      "schedule": [
        "before 5am on monday"
      ]
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "schedule": [
        "before 5am on monday"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.env$/",
        "/(^|/)Dockerfile\\.agent$/"
      ],
      "matchStrings": [
        "CLAUDE_NODE_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)",
        "CODEX_NODE_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)",
        "DOCKER_CLI_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
        "DOCKER_DIND_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?",
        "ARG CLAUDE_NODE_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)",
        "ARG CODEX_NODE_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)",
        "ARG DOCKER_CLI_IMAGE=(?<depName>[\\w./-]+):(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.env$/",
        "/(^|/)Dockerfile\\.agent$/"
      ],
      "matchStrings": [
        "CLAUDE_CODE_VERSION=(?<currentValue>[^\\s]+)",
        "ARG CLAUDE_CODE_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "@anthropic-ai/claude-code",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.env$/",
        "/(^|/)Dockerfile\\.agent$/"
      ],
      "matchStrings": [
        "CODEX_VERSION=(?<currentValue>[^\\s]+)",
        "ARG CODEX_VERSION=(?<currentValue>[^\\s]+)"
      ],
      "depNameTemplate": "@openai/codex",
      "datasourceTemplate": "npm"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.env$/",
        "/(^|/)Dockerfile\\.agent$/"
      ],
      "matchStrings": [
        "HELM_VERSION=(?<currentValue>v?[^\\s]+)",
        "ARG HELM_VERSION=(?<currentValue>v?[^\\s]+)"
      ],
      "depNameTemplate": "helm/helm",
      "datasourceTemplate": "github-releases"
    }
  ]
}
